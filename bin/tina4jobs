#!/usr/bin/env php
<?php

use Tina4Jobs\Tina4Queue\Tina4JobFactory;

$replacePath = $argv[0]; //used to figure out where we're running
global $rootPath;
global $session; //store things here you want to reuse
$session = [];

// --- parse queue name from argv ---
$queueName = "default";
if (!empty($argv) && is_array($argv)) {
    // Start at 1 to skip script name
    for ($i = 1; $i < count($argv); $i++) {
        $arg = $argv[$i];

        if (str_starts_with($arg, '--queue=')) {
            $queueName = substr($arg, strlen('--queue='));
            continue;
        }

        if (str_starts_with($arg, '-q=')) {
            $queueName = substr($arg, strlen('-q='));
            continue;
        }

        if ($arg === '--queue' || $arg === '-q') {
            // next value should be the queue name
            if (isset($argv[$i + 1]) && !str_starts_with($argv[$i + 1], '-')) {
                $queueName = $argv[$i + 1];
                $i++; // skip next
            }
            continue;
        }
    }
}
// --- end parse queue name from argv ---

foreach (get_included_files() as $id => $file) {
    if (strpos($file, "vendor" . DIRECTORY_SEPARATOR . "autoload.php")) {
        $rootPath = str_ireplace("vendor" . DIRECTORY_SEPARATOR . "autoload.php", "", $file);
        break;
    }
}

if (empty($rootPath)) {
    $rootPath = str_replace("vendor" . DIRECTORY_SEPARATOR . "tina4components" . DIRECTORY_SEPARATOR . "tina4jobsmodule" . DIRECTORY_SEPARATOR . "bin" . DIRECTORY_SEPARATOR . "tina4jobs", "", __FILE__);
    $rootPath = str_replace("bin" . DIRECTORY_SEPARATOR . "tina4jobs", "", $rootPath);
}

require_once "{$rootPath}vendor/autoload.php";
define("TINA4_SUPPRESS", true);

if (file_exists($rootPath . "index.php")) {
    include_once $rootPath . "index.php";
}

//Garbage collection
gc_enable();
try {
    // Initialize the job queue using the factory, which chooses the driver based on config
    $jobQueue = Tina4JobFactory::createQueueDriver();

    echo "Starting job processor for queue: {$queueName}\n";

    // Flag to manage graceful shutdown
    $shouldStop = false;

    // Register signal handlers for graceful shutdown
    if (function_exists('pcntl_signal')) {
        pcntl_signal(SIGTERM, function () use (&$shouldStop) {
            echo "Received shutdown signal, stopping...\n";
            $shouldStop = true;
        });
        pcntl_signal(SIGINT, function () use (&$shouldStop) {
            echo "Received shutdown signal, stopping...\n";
            $shouldStop = true;
        });

        pcntl_signal(SIGALRM, function() use (&$shouldStop, $jobQueue, &$nextJob, $queueName) {
            echo "Job timed out, marking as failed...\n";
            if (property_exists($nextJob, 'jobId')) {
                try {
                    $jobQueue->markJobFailed('Timeout', $nextJob->getJobId(), convert_uuencode(serialize($nextJob)), $queueName);
                } catch (Exception $exception) {
                    echo "Failed to mark job as failed: " . $exception->getMessage() . "\n";

                    $shouldStop = true; // Stop processing on failure to mark job
                }
            }
            // Optionally, throw an exception to break out of job processing
            echo "Job timed out and marked as failed.\n";
        });
    }

    // Start the job processing loop
    while (!$shouldStop) {
        // Dispatch any pending signals
        if (function_exists('pcntl_signal_dispatch')) {
            pcntl_signal_dispatch();
        }

        // Attempt to get the next job in the queue
        $nextJob = $jobQueue->getNextJob($queueName);

        if ($nextJob) {
            echo "Processing job: " . get_class($nextJob) . "\n";

            try {

                // Set an alarm for job timeout
                if (function_exists('pcntl_alarm')) {
                    pcntl_alarm($nextJob->getTimeoutAfterTime());
                }

                // Process the job here
                if (get_class($nextJob) !== "__PHP_Incomplete_Class") {
                    $nextJob->handle();
                }

                if (function_exists('pcntl_alarm')) {
                    pcntl_alarm(0); // Cancel alarm
                }

                // Mark job as completed (you’ll need to pass the actual job ID)
                if (property_exists($nextJob, 'jobId') && !empty($nextJob->getJobId())) {
                    $jobQueue->markJobCompleted($nextJob->getJobId());
                    echo "Job completed: ID " . $nextJob->getJobId() . "\n";
                }
            } catch (Exception $e) {
                if (function_exists('pcntl_alarm')) {
                    pcntl_alarm(0); // Cancel alarm on exception
                }

                $shouldRetry = false;

                //Check if max attempts have been reached if not the allow retry
                if(property_exists($nextJob, 'attempts')) {
                    if($nextJob->attempt()) {
                        $shouldRetry = true;
                    }
                }

                if($shouldRetry) {
                    $jobQueue->releaseJob($nextJob, $nextJob->getTimeBetweenAttempts(), $queueName);
                } else {
                    $jobQueue->markJobFailed(serialize($e), $nextJob->getJobId() ?? -1, convert_uuencode(serialize($nextJob)), $queueName);
                }

            }

            // Perform garbage collection to free up memory
            gc_collect_cycles();

        } else {
            // No jobs in the queue, wait before checking again
            echo "No jobs found. Waiting...\n";
        }

        // Sleep for a defined interval before checking for the next job
        sleep(5); // Adjust the sleep time as needed (in seconds)
    }

    echo "Job processor stopped gracefully.\n";

} catch (Exception $e) {
    echo "Error: " . $e->getMessage() . "\n";
}