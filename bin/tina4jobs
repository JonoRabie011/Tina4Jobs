#!/usr/bin/env php
<?php

use Tina4Jobs\Tina4Queue\Tina4JobFactory;

$replacePath = $argv[0];

global $rootPath;
global $session;

$session = [];

// ----------------------
// Parse queue argument
// ----------------------

$queueName = "default";

if (!empty($argv) && is_array($argv)) {
    for ($i = 1; $i < count($argv); $i++) {

        $arg = $argv[$i];

        if (str_starts_with($arg, '--queue=')) {
            $queueName = substr($arg, strlen('--queue='));
            continue;
        }

        if (str_starts_with($arg, '-q=')) {
            $queueName = substr($arg, strlen('-q='));
            continue;
        }

        if ($arg === '--queue' || $arg === '-q') {
            if (isset($argv[$i + 1]) && !str_starts_with($argv[$i + 1], '-')) {
                $queueName = $argv[$i + 1];
                $i++;
            }
        }
    }
}

// ----------------------
// Resolve project root
// ----------------------

foreach (get_included_files() as $file) {
    if (strpos($file, "vendor" . DIRECTORY_SEPARATOR . "autoload.php")) {
        $rootPath = str_ireplace("vendor" . DIRECTORY_SEPARATOR . "autoload.php", "", $file);
        break;
    }
}

if (empty($rootPath)) {
    $rootPath = str_replace(
            "vendor" . DIRECTORY_SEPARATOR . "tina4components" . DIRECTORY_SEPARATOR . "tina4jobsmodule" . DIRECTORY_SEPARATOR . "bin" . DIRECTORY_SEPARATOR . "tina4jobs",
            "",
            __FILE__
    );

    $rootPath = str_replace("bin" . DIRECTORY_SEPARATOR . "tina4jobs", "", $rootPath);
}

require_once "{$rootPath}vendor/autoload.php";

define("TINA4_SUPPRESS", true);

if (file_exists($rootPath . "index.php")) {
    include_once $rootPath . "index.php";
}

gc_enable();

try {

    $jobQueue = Tina4JobFactory::createQueueDriver();

    echo "Starting job processor for queue: {$queueName}\n";

    $shouldStop = false;

    // ----------------------
    // Worker config
    // ----------------------

    $maxWorkers = 10;
    $children = [];
    $maxMemory = 256 * 1024 * 1024;

    // ----------------------
    // Signal handling
    // ----------------------

    if (function_exists('pcntl_signal')) {

        pcntl_signal(SIGTERM, function () use (&$shouldStop) {
            echo "SIGTERM received. Shutting down...\n";
            $shouldStop = true;
        });

        pcntl_signal(SIGINT, function () use (&$shouldStop) {
            echo "SIGINT received. Shutting down...\n";
            $shouldStop = true;
        });

    }

    // ----------------------
    // Worker Loop
    // ----------------------

    while (!$shouldStop) {

        pcntl_signal_dispatch();

        // Reap finished children
        foreach ($children as $pid => $jobId) {

            $result = pcntl_waitpid($pid, $status, WNOHANG);

            if ($result > 0) {
                unset($children[$pid]);
            }
        }

        // Memory protection
        if (memory_get_usage(true) > $maxMemory) {
            echo "Memory limit reached. Restarting worker...\n";
            exit;
        }

        // Limit worker count
        if (count($children) >= $maxWorkers) {
            usleep(500000);
            continue;
        }

        // Fetch next job
        $nextJob = $jobQueue->getNextJob($queueName);

        if (!$nextJob) {
            echo "No jobs found. Waiting...\n";
            sleep(2);
            continue;
        }

        if (get_class($nextJob) === "__PHP_Incomplete_Class") {
            echo "Invalid job payload.\n";
            continue;
        }

        echo "Processing job: " . get_class($nextJob) . "\n";

        $pid = pcntl_fork();

        if ($pid == -1) {
            throw new Exception("Failed to fork worker");
        }

        if ($pid) {
            // Parent
            $children[$pid] = $nextJob->getJobId();
            continue;
        }

        // ----------------------
        // CHILD PROCESS
        // ----------------------

        runJob($nextJob, $jobQueue, $queueName);

        exit(0);
    }

    echo "Worker shutting down gracefully\n";

} catch (Exception $e) {

    echo "Worker error: " . $e->getMessage() . "\n";

}

// ----------------------
// Job Runner
// ----------------------

function runJob($job, $jobQueue, $queueName)
{

    try {

        if (function_exists('pcntl_alarm')) {
            pcntl_alarm($job->getTimeoutAfterTime());
        }

        $job->handle();

        if (property_exists($job, 'jobId') && !empty($job->getJobId())) {

            $jobQueue->markJobCompleted(
                    $job->getJobId()
            );

            echo "Job completed: " . $job->getJobId() . "\n";
        }

    } catch (Throwable $e) {

        echo "Job failed: " . $e->getMessage() . "\n";

        $shouldRetry = false;

        if (property_exists($job, 'attempts')) {

            if ($job->attempt()) {
                $shouldRetry = true;
            }

        }

        if ($shouldRetry) {

            $jobQueue->releaseJob(
                    $job,
                    $job->getTimeBetweenAttempts(),
                    $queueName
            );

            echo "Job released back to queue\n";

        } else {

            $jobQueue->markJobFailed(
                    serialize($e),
                    $job->getJobId() ?? -1,
                    convert_uuencode(serialize($job)),
                    $queueName
            );

            echo "Job permanently failed\n";

        }

    }

    if (function_exists('pcntl_alarm')) {
        pcntl_alarm(0);
    }

    gc_collect_cycles();
}